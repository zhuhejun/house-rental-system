<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kmbeast.mapper.HouseOrderEvaluationsMapper">

    <select id="list" resultMap="BaseResultMap">
        SELECT
        hoe.id,
        hoe.user_id,
        hoe.house_order_info_id,
        hoe.text,
        hoe.score,
        hoe.status,
        hoe.create_time,
        (SELECT COUNT(*) FROM content_report cr WHERE cr.target_type = 2 AND cr.target_id = hoe.id) AS reportCount,
        u.username,
        u.avatar
        FROM house_order_evaluations hoe
        LEFT JOIN user u ON u.id = hoe.user_id
        <where>
            <if test="userId != null">
                AND hoe.user_id = #{userId}
            </if>
            <if test="houseOrderInfoId != null">
                AND hoe.house_order_info_id = #{houseOrderInfoId}
            </if>
            <if test="houseOrderInfoIds != null and houseOrderInfoIds.size>0">
                AND hoe.house_order_info_id IN
                <foreach collection="houseOrderInfoIds" item="houseOrderInfoId" separator="," open="(" close=")" index="index">
                    #{houseOrderInfoId}
                </foreach>
            </if>
            <if test="text != null and text != ''">
                AND hoe.text like concat('%',#{text},'%')
            </if>
            <if test="reportedOnly != null and reportedOnly">
                AND EXISTS (
                SELECT 1
                FROM content_report cr
                WHERE cr.target_type = 2
                AND cr.target_id = hoe.id
                )
            </if>
            <if test="status != null">
                AND hoe.status = #{status}
            </if>
        </where>
        <if test="current != null and size != null">
            LIMIT #{current},#{size}
        </if>
    </select>

    <!--满足分页条件的数据总项-->
    <select id="listCount" resultType="integer">

        SELECT COUNT(*)
        FROM house_order_evaluations hoe
        <where>
            <if test="userId != null">
                AND hoe.user_id = #{userId}
            </if>
            <if test="houseOrderInfoId != null">
                AND hoe.house_order_info_id = #{houseOrderInfoId}
            </if>
            <if test="text != null and text != ''">
                AND hoe.text like concat('%',#{text},'%')
            </if>
            <if test="reportedOnly != null and reportedOnly">
                AND EXISTS (
                SELECT 1
                FROM content_report cr
                WHERE cr.target_type = 2
                AND cr.target_id = hoe.id
                )
            </if>
            <if test="status != null">
                AND hoe.status = #{status}
            </if>
        </where>
    </select>

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kmbeast.pojo.vo.HouseOrderEvaluationsVO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="avatar" property="avatar"/>
        <result column="house_order_info_id" property="houseOrderInfoId"/>
        <result column="text" property="text"/>
        <result column="score" property="score"/>
        <result column="status" property="status"/>
        <result column="reportCount" property="reportCount"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

</mapper>
