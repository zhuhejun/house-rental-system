{"remainingRequest":"D:\\house-rental-system\\source code\\view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\house-rental-system\\source code\\view\\src\\views\\user\\NoticeDetail.vue?vue&type=script&lang=js&","dependencies":[{"path":"D:\\house-rental-system\\source code\\view\\src\\views\\user\\NoticeDetail.vue","mtime":1752828674000},{"path":"D:\\house-rental-system\\source code\\view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773061148748},{"path":"D:\\house-rental-system\\source code\\view\\node_modules\\vue-loader\\lib\\index.js","mtime":1773061140950}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["NoticeDetail.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;AAqBA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"NoticeDetail.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\n    <div class=\"container-notice\">\n        <!-- 公告标题 -->\n        <div class=\"title\">\n            {{ notice.title }}\n        </div>\n        <!-- 公告发布时间 -->\n        <div class=\"time\">\n            发布于{{ notice.createTime }}\n        </div>\n        <!-- 公告内容 -->\n        <div v-html=\"notice.content\"></div>\n        <!-- 评论模块嵌入 -->\n        <div>\n            <Evaluations :userId=\"Number(userId)\" :avatar=\"String(avatar)\" :contentId=\"Number(noticeId)\"\n                contentType=\"NOTICE\" />\n        </div>\n    </div>\n</template>\n\n<script>\nimport Evaluations from \"@/components/Evaluations\"\nexport default {\n    components: { Evaluations },\n    data() {\n        return {\n            noticeId: null,\n            notice: {},\n            userId: null,\n            avatar: '',\n        }\n    },\n    created() {\n        this.getPathId();\n        this.fetchUserInfo();\n    },\n    methods: {\n        getPathId() {\n            this.noticeId = this.$route.query.id;\n            this.fetchNoticeInfo(this.noticeId);\n        },\n        async fetchUserInfo() {\n            try {\n                const { data } = await this.$axios.get(`/user/auth`);\n                this.userId = data.id;\n                this.avatar = data.avatar;\n            } catch (error) {\n                this.$message.error('获取用户信息失败');\n                console.error(error);\n            }\n        },\n        async fetchNoticeInfo(id) {\n            try {\n                const { data } = await this.$axios.get(`/notice/getById/${id}`);\n                this.notice = { ...data };\n            } catch (error) {\n                this.$message.error('获取公告信息失败');\n                console.error(error);\n            }\n        },\n    }\n}\n</script>\n\n<style scoped lang=\"scss\">\n\n.container-notice{\n    width: 700px;\n    margin: 0 auto;\n    padding-block: 30px;\n    .title{\n        font-size: 40px;\n        margin-block: 10px;\n    }\n}\n\n</style>"]}]}